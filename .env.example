# Backend API Configuration
# The base URL for the backend API
# Default: http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000/api

# Example for production:
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# Example for Docker deployment:
# VITE_API_BASE_URL=http://backend:3000/api

# Comma-separated list of version options for the filter dropdown
# Default: (todas),1.0.3,1.0.4,1.0.5,1.0.6,1.0.7,1.0.8,1.0.9,1.0.10,1.0.11
VITE_VERSION_OPTIONS=(todas),1.0.3,1.0.4,1.0.5,1.0.6,1.0.7,1.0.8,1.0.9,1.0.10,1.0.11

# Default version selected in the filter
# Default: 1.0.11
VITE_DEFAULT_VERSION=1.0.11
